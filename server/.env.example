PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# VATSIM OAuth (https://auth.vatsim.net for production, https://auth-dev.vatsim.net for sandbox)
VATSIM_AUTH_URL=https://auth-dev.vatsim.net
VATSIM_CLIENT_ID=
VATSIM_CLIENT_SECRET=
VATSIM_REDIRECT_URI=http://localhost:3001/auth/vatsim/callback

# JWT signing secret — use a long random string in production
JWT_SECRET=dev-secret-change-me
